{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/Hacemos cocina - Home.html" },
    { "source": "/home", "destination": "/Hacemos cocina - Home.html" },
    { "source": "/mobile", "destination": "/Hacemos cocina - Mobile.html" },
    { "source": "/offline", "destination": "/Hacemos cocina - Home offline.html" },
    { "source": "/standalone", "destination": "/Hacemos cocina - Home standalone.html" }
  ],
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/styles/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" },
        { "key": "Content-Type", "value": "text/css; charset=utf-8" }
      ]
    },
    {
      "source": "/scripts/(.*\\.jsx)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" },
        { "key": "Content-Type", "value": "text/babel; charset=utf-8" }
      ]
    },
    {
      "source": "/(.*\\.jsx)",
      "headers": [
        { "key": "Content-Type", "value": "text/babel; charset=utf-8" }
      ]
    },
    {
      "source": "/(.*\\.woff2)",
      "headers": [
        { "key": "Content-Type", "value": "font/woff2" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.ttf)",
      "headers": [
        { "key": "Content-Type", "value": "font/ttf" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
